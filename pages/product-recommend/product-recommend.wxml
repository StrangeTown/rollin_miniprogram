</navigation-bar>

<view class="page">
  <view class="section-title">公众号</view>
  <view class="product-card" bindtap="openOfficialAccount" hover-class="product-card-press" hover-start-time="0" hover-stay-time="80">
    <view class="product-info">
      <view class="product-name">每日一篇英语阅读</view>
      <view class="product-desc">每天一篇英语短文，轻松提升阅读能力</view>
