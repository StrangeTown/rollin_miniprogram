<navigation-bar title="{{navTitle}}" back="{{true}}" color="black" background="#FAFAFA">
</navigation-bar>

<view class="page">
  <!-- Progress Bar (instead of simple counter) -->
  <view wx:if="{{!finished}}" class="progress-wrapper">
    <view class="counter-text">{{current}} / {{totalCount}}</view>
    <view class="progress-bar-bg">
      <view class="progress-bar-fill" style="width: {{(current / totalCount) * 100}}%"></view>
    </view>
    <view class="settings-dot-entry" bindtap="openSettingsSheet">☰</view>
  </view>

  <!-- Main card area -->
  <view wx:if="{{!finished}}" class="card-area {{cardAnim}}">
    <!-- Structure (the pattern) in a decorative banner -->
    <view wx:if="{{!isScenarioMode && !hideStructureBanner}}" class="structure-banner {{!showStructure ? 'structure-banner-hidden' : ''}}" bindtap="revealStructure">
      <view class="structure-quote">“</view>
      <view class="structure-label {{!showStructure ? 'structure-label-obscured' : ''}}">{{structure}}</view>
      <view wx:if="{{!showStructure}}" class="structure-reveal-mask">
        <view class="structure-reveal-text">点击查看</view>
      </view>
    </view>

    <!-- Content Card -->
    <view class="card">
      <view class="card-hint">
        <text class="hint-icon">{{isScenarioMode || isScenarioItem ? '🗺️' : '🧩'}}</text>
        <text>试着翻译这句话：</text>
      </view>
      
      <view class="content-section">
        <view class="card-zh">{{zh}}</view>
        
        <!-- English answer (hidden until revealed) -->
        <view class="card-en {{showAnswer ? 'revealed' : ''}}">
          <view wx:if="{{showAnswer}}" class="en-text">{{en}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{showAnswer && isReviewMode && recallPreviousInReview && previousPromptZh}}" class="review-recap">
      <text class="review-recap-line">
        <text class="review-recap-title">上一句：</text>
        <text class="review-recap-zh">{{previousPromptZh}}</text>
      </text>
    </view>

  </view>

  <view wx:if="{{!finished}}" class="btn-area">
    <view wx:if="{{!showAnswer}}" class="reveal-btn" bindtap="revealAnswer" hover-class="reveal-btn-press" hover-start-time="0" hover-stay-time="80">
      <text>查看英文</text>
    </view>
    <view wx:if="{{showAnswer}}" class="next-btn" bindtap="nextQuestion" hover-class="next-btn-press" hover-start-time="0" hover-stay-time="80">
      <text>{{(current < totalCount || autoLoopPractice) ? '下一句' : '完成练习'}}</text>
      <text class="btn-icon" wx:if="{{current < totalCount || autoLoopPractice}}">→</text>
    </view>
  </view>

  <!-- Finished state -->
  <view wx:if="{{finished}}" class="finished-area">
    <view class="finished-emoji">🎉</view>
    <view class="finished-title">练习完成！</view>
    <view class="finished-desc">第 {{round}} 轮 · 已完成 {{totalCount}} 句造句练习</view>
    <view class="again-btn" bindtap="replayRound">再练一遍</view>
    <view class="back-link" bindtap="goBack">返回首页</view>
  </view>

</view>

<view wx:if="{{showSettingsSheet}}" class="settings-sheet-mask" bindtap="closeSettingsSheet" catchtouchmove="noop">
  <view class="settings-sheet" catchtap="noop" catchtouchmove="noop">
    <view class="sheet-header">
      <view class="sheet-close" bindtap="closeSettingsSheet">关闭</view>
    </view>

    <view class="sheet-body">
      <view wx:if="{{!isScenarioMode && !hideStructureBanner}}" class="sheet-setting-item action-item" bindtap="openAddDialog">
        <view class="sheet-setting-left">
          <view class="sheet-setting-title">添加例句</view>
          <view class="sheet-setting-desc">结合你的生活场景，写一个例句</view>
        </view>
        <view class="sheet-action-icon"></view>
      </view>

      <view class="sheet-setting-item mt-24">
        <view class="sheet-setting-left">
          <view class="sheet-setting-title">循环练习</view>
          <view class="sheet-setting-desc">最后一题点击下一句后自动洗牌并开始下一轮</view>
        </view>
        <switch checked="{{autoLoopPractice}}" color="#111827" bindchange="onAutoLoopChange" />
      </view>

      <view wx:if="{{isReviewMode}}" class="sheet-setting-item">
        <view class="sheet-setting-left">
          <view class="sheet-setting-title">默认隐藏英语语块</view>
          <view class="sheet-setting-desc">回顾模式下先自行回忆，点击顶部语块区域后再显示</view>
        </view>
        <switch checked="{{blurStructureInReview}}" color="#111827" bindchange="onReviewBlurChange" />
      </view>

      <view wx:if="{{isReviewMode}}" class="sheet-setting-item">
        <view class="sheet-setting-left">
          <view class="sheet-setting-title">回顾上一句</view>
          <view class="sheet-setting-desc">查看当前例句时，顺手回顾上一句</view>
        </view>
        <switch checked="{{recallPreviousInReview}}" color="#111827" bindchange="onReviewRecallChange" />
      </view>

      <view wx:if="{{isReviewMode}}" class="sheet-setting-item action-item"  bindtap="startAutoPlay">
        <view class="sheet-setting-left">
          <view class="sheet-setting-title">自动播放</view>
          <view class="sheet-setting-desc">自动轮播中文例句，在有限时间里快速回顾对应的英文</view>
        </view>
        <view class="sheet-action-icon"></view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showAutoPlay}}" class="autoplay-mask" catchtouchmove="noop">
  <view class="autoplay-content">
    <view class="autoplay-zh {{autoPlayZhVisible ? '' : 'autoplay-zh-hidden'}}">{{autoPlayZh}}</view>
  </view>

  <view class="autoplay-ring-wrap" bindtap="openSpeedSheet">
    <canvas type="2d" id="autoplayRing" class="autoplay-ring-canvas"></canvas>
  </view>

  <view class="autoplay-close" bindtap="stopAutoPlay">关闭</view>

  <view wx:if="{{showSpeedSheet}}" class="speed-sheet-mask" bindtap="closeSpeedSheet" catchtouchmove="noop">
    <view class="speed-sheet" catchtap="noop">
      <view class="speed-sheet-title">切换速度</view>
      <view class="speed-options">
        <view class="speed-option {{autoPlaySpeed === 3000 ? 'speed-option-active' : ''}}" data-speed="3000" bindtap="pickSpeed">3s</view>
        <view class="speed-option {{autoPlaySpeed === 5000 ? 'speed-option-active' : ''}}" data-speed="5000" bindtap="pickSpeed">5s</view>
        <view class="speed-option {{autoPlaySpeed === 8000 ? 'speed-option-active' : ''}}" data-speed="8000" bindtap="pickSpeed">8s</view>
      </view>

      <view class="speed-sheet-divider"></view>

      <view class="flash-option" bindtap="toggleFlash">
        <view class="flash-option-left">
          <view class="flash-option-title">闪现模式</view>
          <view class="flash-option-desc">汉语只显示 1 秒后消失，训练瞬间记忆</view>
        </view>
        <switch checked="{{autoPlayFlash}}" color="#6366F1" />
      </view>
    </view>
  </view>
</view>
