page {
  background-color: #FAFAFA;
}

.page {
  min-height: 100vh;
  background-color: #FAFAFA;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* Progress */
.progress-bar {
  width: 100%;
  margin-top: 24rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 12rpx;
}

.progress-track {
  width: 100%;
  height: 8rpx;
  background: rgba(17, 24, 39, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #111827;
  border-radius: 4rpx;
  transition: width 0.4s ease;
}

/* Done banner */
.done-banner {
  width: 100%;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  text-align: center;
}

.done-text {
  font-size: 26rpx;
  color: #6B7280;
}

/* Progress Container */
.progress-container {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-bar-bg {
  flex: 1;
  height: 8rpx;
  background: rgba(17, 24, 39, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 24rpx;
}

.progress-bar-fill {
  height: 100%;
  background: #111827;
  border-radius: 4rpx;
  transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.counter-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #6B7280;
  white-space: nowrap;
  display: flex;
  align-items: baseline;
}

.counter-total {
  font-size: 24rpx;
  font-weight: 400;
  color: #9CA3AF;
  margin-left: 6rpx;
}

/* Card area */
.card-area {
  width: 100%;
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Structure banner */
.structure-banner {
  position: relative;
  width: 100%;
  padding: 40rpx 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

.structure-quote {
  position: absolute;
  top: -20rpx;
  left: 20rpx;
  font-size: 160rpx;
  color: rgba(17, 24, 39, 0.03);
  font-family: Georgia, serif;
  line-height: 1;
}

.structure-label {
  font-size: 60rpx;
  font-weight: 800;
  color: #111827;
  text-align: center;
  letter-spacing: 0;
  z-index: 1;
  white-space: normal;
  word-break: normal;
  overflow-wrap: normal;
}

/* Card */
.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 56rpx 48rpx;
  box-shadow: 0 40rpx 80rpx -12rpx rgba(0, 0, 0, 0.06), 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
}

.card-hint {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 32rpx;
  background: #F9FAFB;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  width: fit-content;
  font-weight: 500;
}

.hint-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.content-section {
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-zh {
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.6;
}

.card-en {
  margin-top: 0;
  height: 0;
  opacity: 0;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.card-en.revealed {
  margin-top: 40rpx;
  height: auto;
  opacity: 1;
  padding-top: 40rpx;
  border-top: 2rpx dashed #E5E7EB;
}

.en-text {
  font-size: 36rpx;
  font-weight: 500;
  color: #111827;
  line-height: 1.5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* Buttons */
.btn-area {
  width: 100%;
  margin-top: 80rpx;
}

.reveal-btn,
.next-btn {
  width: 100%;
  height: 104rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal-btn {
  background: #111827;
  color: #FFFFFF;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
}

.next-btn {
  background: #FFFFFF;
  color: #111827;
  border: 2rpx solid #E5E7EB;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.03);
}

.btn-icon {
  margin-left: 12rpx;
  font-size: 36rpx;
  font-weight: 400;
}

.reveal-btn:active,
.next-btn:active {
  transform: scale(0.97);
}

/* Card animations */
.card-leave {
  animation: cardLeave 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.card-enter {
  animation: cardEnter 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes cardLeave {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-40rpx) scale(0.96);
  }
}

@keyframes cardEnter {
  0% {
    opacity: 0;
    transform: translateY(40rpx) scale(0.96);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* Finished state */
.finished-area {
  margin-top: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finished-emoji {
  font-size: 100rpx;
}

.finished-title {
  margin-top: 40rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #111827;
}

.finished-desc {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #6B7280;
}

.again-btn {
  margin-top: 80rpx;
  width: 440rpx;
  height: 104rpx;
  background: #111827;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.again-btn:active {
  transform: scale(0.97);
}

.back-link {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 16rpx 32rpx;
  font-weight: 500;
}

.back-link:active {
  color: #6B7280;
}
