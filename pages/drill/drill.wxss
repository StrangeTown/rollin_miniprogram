page {
  background-color: #FAFAFA;
}

.page {
  min-height: 100vh;
  background-color: #FAFAFA;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx 180rpx;
  box-sizing: border-box;
}

/* Progress */
.progress-bar {
  width: 100%;
  margin-top: 24rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 12rpx;
}

.progress-track {
  width: 100%;
  height: 8rpx;
  background: rgba(17, 24, 39, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #111827;
  border-radius: 4rpx;
  transition: width 0.4s ease;
}

/* Done banner */
.done-banner {
  width: 100%;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  text-align: center;
}

.done-text {
  font-size: 26rpx;
  color: #6B7280;
}

/* Progress Container */
.progress-wrapper {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.counter-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #9CA3AF;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.settings-dot-entry {
  font-size: 40rpx;
  font-weight: 400;
  color: #9CA3AF;
  padding: 10rpx 0 10rpx 20rpx;
  margin-right: -4rpx;
  transition: all 0.2s ease;
  line-height: 1;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.settings-dot-entry:active {
  color: #6B7280;
  transform: scale(0.95);
}

.progress-bar-bg {
  flex: 1;
  height: 10rpx;
  background: rgba(17, 24, 39, 0.05);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #111827;
  border-radius: 5rpx;
  transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Card area */
.card-area {
  width: 100%;
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Structure banner */
.structure-banner {
  position: relative;
  width: 100%;
  padding: 40rpx 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

.structure-quote {
  position: absolute;
  top: -20rpx;
  left: 20rpx;
  font-size: 160rpx;
  color: rgba(17, 24, 39, 0.03);
  font-family: Georgia, serif;
  line-height: 1;
}

.structure-label {
  font-size: 60rpx;
  font-weight: 800;
  color: #111827;
  text-align: center;
  letter-spacing: 0;
  z-index: 1;
  white-space: normal;
  word-break: normal;
  overflow-wrap: normal;
}

/* Card */
.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 56rpx 48rpx;
  box-shadow: 0 40rpx 80rpx -12rpx rgba(0, 0, 0, 0.06), 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
}

.card-hint {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 32rpx;
  background: #F9FAFB;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  width: fit-content;
  font-weight: 500;
}

.hint-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.content-section {
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-zh {
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.6;
}

.card-en {
  margin-top: 0;
  height: 0;
  opacity: 0;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.card-en.revealed {
  margin-top: 40rpx;
  height: auto;
  opacity: 1;
  padding-top: 40rpx;
  border-top: 2rpx dashed #E5E7EB;
}

.en-text {
  font-size: 36rpx;
  font-weight: 500;
  color: #111827;
  line-height: 1.5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* Buttons */
.btn-area {
  width: 100%;
  margin-top: 80rpx;
}

.reveal-btn,
.next-btn {
  width: 100%;
  height: 104rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal-btn {
  background: #111827;
  color: #FFFFFF;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
}

.next-btn {
  background: #FFFFFF;
  color: #111827;
  border: 2rpx solid #E5E7EB;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.03);
}

.btn-icon {
  margin-left: 12rpx;
  font-size: 36rpx;
  font-weight: 400;
}

.reveal-btn:active,
.next-btn:active {
  transform: scale(0.97);
}

/* Card animations */
.card-leave {
  animation: cardLeave 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.card-enter {
  animation: cardEnter 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes cardLeave {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-40rpx) scale(0.96);
  }
}

@keyframes cardEnter {
  0% {
    opacity: 0;
    transform: translateY(40rpx) scale(0.96);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* Finished state */
.finished-area {
  margin-top: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finished-emoji {
  font-size: 100rpx;
}

.finished-title {
  margin-top: 40rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #111827;
}

.finished-desc {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #6B7280;
}

.again-btn {
  margin-top: 80rpx;
  width: 440rpx;
  height: 104rpx;
  background: #111827;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.again-btn:active {
  transform: scale(0.97);
}

.back-link {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 16rpx 32rpx;
  font-weight: 500;
}

.back-link:active {
  color: #6B7280;
}

.settings-sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  background: rgba(17, 24, 39, 0.4);
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.settings-sheet {
  width: 100%;
  height: 78vh;
  background: #FAFAFA;
  border-radius: 48rpx 48rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  animation: sheetUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
}

@keyframes sheetUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.sheet-grabber {
  width: 80rpx;
  height: 10rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin: 24rpx auto 12rpx;
  flex-shrink: 0;
}

.sheet-header {
  height: 96rpx;
  padding: 0 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.sheet-close {
  position: absolute;
  right: 32rpx;
  min-height: 88rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #6B7280;
  display: flex;
  align-items: center;
  transition: color 0.2s;
}

.sheet-close:active {
  color: #111827;
}

.sheet-body {
  flex: 1;
  padding: 32rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  overflow-y: auto;
  box-sizing: border-box;
}

.sheet-setting-item {
  width: 100%;
  min-height: 144rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 24rpx;
}

.sheet-setting-left {
  flex: 1;
  margin-right: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.sheet-setting-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.sheet-setting-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #6B7280;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.01);
}

.sheet-action-icon {
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid #D1D5DB;
  border-right: 4rpx solid #D1D5DB;
  transform: rotate(45deg);
  border-radius: 2rpx;
  margin-right: 8rpx;
}

/* Add Custom Sentence Dialog */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  background: rgba(17, 24, 39, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.dialog {
  width: 630rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
  animation: dialogZoom 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20vh; /* slightly higher to leave room for keyboard */
}

@keyframes dialogZoom {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.dialog-header {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  text-align: center;
}

.dialog-subtitle {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
  margin-top: 12rpx;
  margin-bottom: 32rpx;
}

.dialog-body {
  margin-bottom: 40rpx;
}

.input-group {
  background: #F3F4F6;
  border-radius: 20rpx;
  padding: 24rpx;
}

.mt-24 {
  margin-top: 24rpx;
}

.dialog-textarea {
  width: 100%;
  min-height: 80rpx;
  font-size: 30rpx;
  color: #111827;
  line-height: 1.5;
}

.input-placeholder {
  color: #9CA3AF;
  font-size: 30rpx;
}

.dialog-footer {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.dialog-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.dialog-btn:active {
  transform: scale(0.95);
}

.cancel-btn {
  background: #F3F4F6;
  color: #4B5563;
}

.save-btn {
  background: #111827;
  color: #FFFFFF;
}
