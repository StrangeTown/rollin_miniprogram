<navigation-bar title="" back="{{false}}" color="black" background="#FAFAFA">
</navigation-bar>

<view class="page">
  <view class="hero">
    <view class="app-title">口语翻翻</view>
    <view class="app-subtitle">通过造句，掌握地道英语语块</view>
  </view>

  <scroll-view scroll-x enhanced enable-flex show-scrollbar="{{false}}" class="entry-scroll">
    <view class="entry-track">
      <view class="entry-card practice-card" data-count="3" bindtap="goToPractice" hover-class="entry-card-press" hover-start-time="0" hover-stay-time="80">
        <view class="card-content">
          <view class="card-title">积累语块</view>
          <view class="card-desc">花1分钟，积累3个语块</view>
        </view>
        <view class="card-emoji">🧩</view>
      </view>
      <view class="entry-card scenario-card" bindtap="goToScenarios" hover-class="entry-card-press" hover-start-time="0" hover-stay-time="80">
        <view class="card-emoji">🗺️</view>
        <view class="card-content">
          <view class="card-title">背记整句</view>
          <view class="card-desc">选个主题，背常用整句</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="history-section" wx:if="{{historySummaries.length > 0}}">
    <view class="section-title" bindtap="showAllRecentHistory">练习记录</view>
    <view class="history-summary-list">
      <view
        class="history-summary-item"
        wx:for="{{historySummaries}}"
        wx:key="dateKey"
        data-date-key="{{item.dateKey}}"
        data-label="{{item.label}}"
        bindtap="showHistoryForDate">
        <view class="history-summary-count">{{item.count}}<text class="count-unit"> 句</text></view>
        <view class="history-summary-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="footer-actions">
    <view class="footer-actions-inner">
      <view class="footer-action-item">
        <view class="footer-entry" bindtap="goToSettings">设置</view>
      </view>
      <view class="footer-divider"></view>
      <view class="footer-action-item footer-share-item">
        <button class="footer-share-btn" open-type="share" hover-class="footer-entry-press" hover-start-time="0" hover-stay-time="80">推荐给朋友</button>
      </view>
    </view>
  </view>

  <bottom-modal
    show="{{showHistory}}"
    title="{{selectedHistoryLabel}}练习记录"
    showCancel="{{true}}"
    cancelText="关闭"
    bind:close="closeHistory">
    <view class="history-modal">
      <scroll-view scroll-y style="height: 50vh"  class="history-list">
        <view class="history-item" wx:for="{{selectedHistoryItems}}" wx:key="id">
          <view class="history-en" wx:if="{{item._scenario}}">{{item.examples[0].en}}</view>
          <view class="history-en" wx:else>{{item.structure}}</view>
          <view class="history-zh">{{item.examples[0].zh}}</view>
        </view>
      </scroll-view>
      <view class="history-action">
        <view class="history-drill-btn" bindtap="drillSelectedItems">练习</view>
      </view>
    </view>
  </bottom-modal>

  <release-notes-modal
    show="{{showReleaseNotes}}"
    releaseNotes="{{releaseNotes}}"
    cancelText="我知道了"
    bind:close="closeReleaseNotes">
  </release-notes-modal>
</view>
