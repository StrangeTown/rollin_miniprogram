<navigation-bar title="" back="{{false}}" color="black" background="#FAFAFA">
</navigation-bar>

<view class="page">
  <view class="hero">
    <view class="app-title">口语翻翻</view>
    <view class="app-subtitle">通过造句，掌握地道英语口语结构</view>
  </view>

  <view class="card-list">
    <view class="practice-card" data-count="3" bindtap="goToPractice" hover-class="practice-card-press" hover-start-time="0" hover-stay-time="80">
      <view class="card-content">
        <view class="card-title">开始练习</view>
        <view class="card-desc">花 1 分钟，练 3 句常用表达</view>
      </view>
      <view class="card-action">
        <view class="play-btn-halo"></view>
        <view class="play-btn">
          <view class="play-icon"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="history-section" wx:if="{{historySummaries.length > 0}}">
    <view class="section-title">练习记录</view>
    <view class="history-summary-list">
      <view
        class="history-summary-item"
        wx:for="{{historySummaries}}"
        wx:key="dateKey"
        data-date-key="{{item.dateKey}}"
        data-label="{{item.label}}"
        bindtap="showHistoryForDate">
        <view class="history-summary-count">{{item.count}}<text class="count-unit"> 句</text></view>
        <view class="history-summary-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="footer-actions">
    <view class="footer-actions-inner">
      <view class="footer-action-item">
        <view class="footer-entry" bindtap="goToSettings">设置</view>
      </view>
      <view class="footer-divider"></view>
      <view class="footer-action-item footer-share-item">
        <button class="footer-share-btn" open-type="share" hover-class="footer-entry-press" hover-start-time="0" hover-stay-time="80">分享给朋友</button>
      </view>
    </view>
  </view>

  <bottom-modal
    show="{{showHistory}}"
    title="{{selectedHistoryLabel}}练习记录"
    showCancel="{{true}}"
    cancelText="关闭"
    bind:close="closeHistory">
    <view class="history-modal">
      <scroll-view scroll-y style="height: 50vh"  class="history-list">
        <view class="history-item" wx:for="{{selectedHistoryItems}}" wx:key="id">
          <view class="history-structure">{{item.structure}}</view>
          <view class="history-example">{{item.examples[0].zh}}</view>
        </view>
      </scroll-view>
      <view class="history-action">
        <view class="history-drill-btn" bindtap="drillSelectedItems">练习这些结构</view>
      </view>
    </view>
  </bottom-modal>

  <release-notes-modal
    show="{{showReleaseNotes}}"
    releaseNotes="{{releaseNotes}}"
    cancelText="我知道了"
    bind:close="closeReleaseNotes">
  </release-notes-modal>
</view>
