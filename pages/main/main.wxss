.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.hero {
  margin-top: 160rpx;
  text-align: center;
}

.app-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 2rpx;
}

.app-subtitle {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #64748b;
}

.card-list {
  margin-top: 92rpx;
  width: 100%;
}

.practice-card {
  width: 100%;
  min-height: 220rpx;
  border-radius: 40rpx;
  padding: 42rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 52%, #f8fbff 100%);
  border: 2rpx solid rgba(59, 130, 246, 0.12);
  box-shadow: 0 18rpx 36rpx rgba(37, 99, 235, 0.12);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.practice-card:active {
  transform: scale(0.96);
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.16);
}

.practice-card::after {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -80rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 72%);
}

.card-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 14rpx;
}

.card-desc {
  max-width: 360rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #4f46e5;
}

.card-right {
  width: 164rpx;
  height: 164rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.motion-orbit {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(59, 130, 246, 0.16);
}

.orbit-one {
  width: 164rpx;
  height: 164rpx;
}

.orbit-two {
  width: 112rpx;
  height: 112rpx;
  border-color: rgba(99, 102, 241, 0.2);
}

.motion-dot {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb 0%, #6366f1 100%);
  box-shadow: 0 0 0 10rpx rgba(99, 102, 241, 0.08);
}

.dot-one {
  top: 32rpx;
  left: 78rpx;
  animation: floatDotOne 2.8s ease-in-out infinite;
}

.dot-two {
  right: 24rpx;
  top: 76rpx;
  animation: floatDotTwo 2.8s ease-in-out 0.35s infinite;
}

.dot-three {
  left: 30rpx;
  bottom: 36rpx;
  animation: floatDotThree 2.8s ease-in-out 0.7s infinite;
}

/* Recent history */
.history-summary-list {
  margin-top: 26rpx;
  width: 100%;
  display: flex;
  gap: 12rpx;
}

.history-summary-item {
  flex: 1;
  min-width: 0;
  border-radius: 22rpx;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(148, 163, 184, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #64748b;
}

.history-summary-item:active {
  opacity: 0.82;
}

.history-summary-label {
  font-size: 24rpx;
  line-height: 1;
}

.history-summary-count {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  color: #0f172a;
}

/* History modal */
.history-modal {
  display: flex;
  flex-direction: column;
}

.history-list {
  padding: 0 8rpx;
}

.history-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.history-item:last-child {
  border-bottom: none;
}

.history-structure {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.history-example {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

.history-action {
  padding-top: 32rpx;
}

.history-drill-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #1e3a8a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-drill-btn:active {
  opacity: 0.85;
}

.reset-btn {
  font-size: 26rpx;
  color: #94a3b8;
  padding: 16rpx 32rpx;
}

.reset-btn:active {
  color: #64748b;
}

@keyframes floatDotOne {
  0%, 100% {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 0.72;
  }
  50% {
    transform: translate3d(0, -10rpx, 0) scale(1.08);
    opacity: 1;
  }
}

@keyframes floatDotTwo {
  0%, 100% {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 0.78;
  }
  50% {
    transform: translate3d(8rpx, 8rpx, 0) scale(1.06);
    opacity: 1;
  }
}

@keyframes floatDotThree {
  0%, 100% {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 0.68;
  }
  50% {
    transform: translate3d(-6rpx, 8rpx, 0) scale(1.12);
    opacity: 1;
  }
}
