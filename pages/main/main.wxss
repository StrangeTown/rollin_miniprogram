page {
  background-color: #FAFAFA;
}

.page {
  min-height: 100vh;
  background-color: #FAFAFA;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.hero {
  margin-top: 140rpx;
  text-align: left;
}

.app-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #111827;
  letter-spacing: 2rpx;
}

.app-subtitle {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #9CA3AF;
  letter-spacing: 1rpx;
  font-weight: 400;
}

.card-list {
  margin-top: 100rpx;
  width: 100%;
}

.practice-card {
  width: 100%;
  border-radius: 48rpx;
  padding: 56rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  box-shadow: 0 40rpx 80rpx -12rpx rgba(0, 0, 0, 0.06), 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  box-sizing: border-box;
  position: relative;
}

.practice-card:active {
  transform: scale(0.97);
  box-shadow: 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.04), 0 10rpx 20rpx -12rpx rgba(0, 0, 0, 0.02);
}

.practice-card-press {
  transform: scale(0.97);
  box-shadow: 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.04), 0 10rpx 20rpx -12rpx rgba(0, 0, 0, 0.02);
}

.practice-card-press .play-btn {
  transform: scale(0.95);
}

.card-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.card-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #6B7280;
  margin-right: 20rpx;
}

.card-action {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.settings-entry {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 0 calc(env(safe-area-inset-bottom) + 32rpx);
  text-align: center;
  font-size: 26rpx;
  color: #9CA3AF;
  transition: color 0.2s;
}

.settings-entry:active {
  color: #9CA3AF;
}

.play-btn-halo {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.04);
  animation: breathingHalo 3s ease-in-out infinite;
}

.play-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  box-shadow: 0 12rpx 24rpx rgba(17, 24, 39, 0.15);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.play-icon {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 14rpx 0 14rpx 22rpx;
  border-color: transparent transparent transparent #FFFFFF;
  margin-left: 6rpx;
  border-radius: 2rpx;
}

/* History section */
.history-section {
  margin-top: 100rpx;
  width: 100%;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #6B7280;
  margin-bottom: 16rpx;
  padding-left: 8rpx; /* 轻微缩进对齐一点视觉边缘 */
}

.history-summary-list {
  width: 100%;
  display: flex;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 40rpx 0;
  box-shadow: 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.03);
}

.history-summary-item {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center; /* 改为居中对齐，重心更稳 */
  justify-content: center;
  transition: opacity 0.2s ease;
}

/* 加上精致的分割线 */
.history-summary-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 15%;
  height: 70%;
  width: 2rpx;
  background: rgba(0, 0, 0, 0.04);
}

.history-summary-item:active {
  opacity: 0.6;
}

.history-summary-count {
  font-size: 48rpx; /* 数字略微放大，增强数据展示感 */
  font-weight: 700;
  line-height: 1;
  color: #111827;
  margin-bottom: 12rpx;
  display: flex;
  align-items: baseline;
}

.count-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #9CA3AF;
  margin-left: 4rpx;
}

.history-summary-label {
  font-size: 26rpx;
  line-height: 1;
  color: #6B7280;
  font-weight: 500;
}

/* History modal */
.history-modal {
  display: flex;
  flex-direction: column;
}

.history-list {
  padding: 0 8rpx;
}

.history-item {
  padding: 32rpx 0;
  border-bottom: 1px solid #F3F4F6;
}

.history-item:last-child {
  border-bottom: none;
}

.history-structure {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.history-example {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.history-action {
  padding-top: 40rpx;
}

.history-drill-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #111827;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
}

.history-drill-btn:active {
  transform: scale(0.98);
}

.release-sheet {
  padding: 8rpx 4rpx 0;
}

.release-version {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.release-title {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.3;
}

.release-summary {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6B7280;
}

.release-list {
  margin-top: 36rpx;
}

.release-item {
  display: flex;
  align-items: flex-start;
}

.release-item-spaced {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #F3F4F6;
}

.release-item-index {
  width: 52rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #9CA3AF;
  line-height: 1.8;
}

.release-item-main {
  flex: 1;
  min-width: 0;
}

.release-item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.5;
}

.release-item-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6B7280;
}

@keyframes breathingHalo {
  0% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.4);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 0;
  }
}
