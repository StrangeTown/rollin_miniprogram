.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.hero {
  margin-top: 160rpx;
  text-align: center;
}

.app-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 2rpx;
}

.app-subtitle {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #64748b;
}

.card-list {
  margin-top: 100rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.practice-card {
  width: 100%;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  box-sizing: border-box;
}

.practice-card:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
}

.card-right {
  display: flex;
  align-items: baseline;
}

.card-num {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
}

.card-unit {
  font-size: 28rpx;
  margin-left: 8rpx;
  font-weight: 600;
}

/* Light Card */
.light-card {
  background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
  border: 2rpx solid #e2e8f0;
  color: #0f172a;
}
.light-card .card-desc {
  color: #64748b;
}

/* Medium Card */
.medium-card {
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  border: 2rpx solid #7dd3fc;
  color: #0f172a;
}
.medium-card .card-desc {
  color: #0369a1;
}
.medium-card .card-right {
  color: #0284c7;
}

/* Dark Card */
.dark-card {
  background: linear-gradient(135deg, #3b82f6 0%, #1e3a8a 100%);
  border: 2rpx solid #2563eb;
  color: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(30, 58, 138, 0.25);
}
.dark-card .card-desc {
  color: #bfdbfe;
}
.dark-card .card-right {
  color: #ffffff;
}

/* Today link */
.today-link {
  margin-top: 48rpx;
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
}

.today-link:active {
  color: #64748b;
}

/* History modal */
.history-modal {
  display: flex;
  flex-direction: column;
}

.history-list {
  padding: 0 8rpx;
}

.history-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.history-item:last-child {
  border-bottom: none;
}

.history-structure {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.history-example {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

.history-action {
  padding-top: 32rpx;
}

.history-drill-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #1e3a8a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-drill-btn:active {
  opacity: 0.85;
}

.reset-btn {
  font-size: 26rpx;
  color: #94a3b8;
  padding: 16rpx 32rpx;
}

.reset-btn:active {
  color: #64748b;
}
