page {
  background-color: #FAFAFA;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  overflow-y: hidden;
}

.page {
  min-height: 100%;
  background-color: #FAFAFA;
  padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
}

.tab-bar {
  display: none;
}

.structure-list {
  margin-top: 0;
}

.structure-card {
  width: 100%;
  padding: 36rpx;
  margin-bottom: 24rpx;
  border-radius: 36rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: flex-start;
}

.structure-index-col {
  width: 44rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 52rpx;
}

.structure-main {
  flex: 1;
  min-width: 0;
  padding-left: 4rpx;
}

.structure-seq {
  font-size: 18rpx;
  font-weight: 500;
  color: #D1D5DB;
  letter-spacing: 0.5rpx;
}

.structure-name {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #111827;
}

.example-preview {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F3F4F6;
}

.example-zh {
  font-size: 28rpx;
  line-height: 1.7;
  color: #111827;
}

.example-en {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9CA3AF;
}

.empty-state {
  margin-top: 28rpx;
  padding: 72rpx 40rpx;
  border-radius: 36rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.03);
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #9CA3AF;
}

.load-more-wrap {
  padding: 32rpx 0 20rpx;
}

.load-more-btn {
  width: 100%;
  color: #9CA3AF;
  font-size: 24rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.18s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}

.load-more-text {
  display: inline-block;
  line-height: 1.6;
  padding-bottom: 1rpx;
  border-bottom: 1rpx solid rgba(156, 163, 175, 0.45);
}

.load-more-btn:active {
  color: #6B7280;
  opacity: 0.8;
}