<navigation-bar title="系统句库" back="{{true}}" color="black" background="#FAFAFA">
</navigation-bar>

<scroll-view class="page-scroll" scroll-y="true" show-scrollbar="{{false}}">
  <view class="page">
    <view class="tab-bar">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        wx:for-item="tabItem"
        class="tab-item {{currentTab === tabItem.key ? 'tab-item-active' : ''}}"
        data-key="{{tabItem.key}}"
        bindtap="switchTab"
      >
        <view class="tab-label">{{tabItem.label}}</view>
        <view class="tab-desc">{{tabItem.description}}</view>
      </view>
    </view>

    <view wx:if="{{visibleItems.length > 0}}" class="structure-list">
      <view
        wx:for="{{visibleItems}}"
        wx:key="id"
        wx:for-item="structureItem"
        wx:for-index="structureIndex"
        class="structure-card"
      >
        <view class="structure-index-col">
          <view class="structure-seq">{{totalCount - structureIndex}}</view>
        </view>

        <view class="structure-main">
          <view class="structure-name">{{structureItem.structure}}</view>

          <view wx:if="{{structureItem.examples.length > 0}}" class="example-preview">
            <view class="example-zh">{{structureItem.examples[0].zh}}</view>
            <view class="example-en">{{structureItem.examples[0].en}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{hasMore}}" class="load-more-wrap">
        <view class="load-more-btn" bindtap="loadMore">
          <text class="load-more-text">加载更多</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-title">还没有内容</view>
      <view class="empty-desc">这个来源下暂时还没有可展示的句子数据。</view>
    </view>
  </view>
</scroll-view>