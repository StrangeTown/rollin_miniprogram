page {
  background-color: #FAFAFA;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page {
  flex: 1;
  background-color: #FAFAFA;
  padding: 24rpx 48rpx;
  box-sizing: border-box;
}

.group-section {
  padding-bottom: 24rpx;
}

.group-section:last-child {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.group-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #6B7280;
  letter-spacing: 1rpx;
  padding: 8rpx 4rpx 20rpx;
}

.scenario-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.scenario-card {
  width: calc(50% - 12rpx);
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx -4rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.scenario-card-press {
  transform: scale(0.96);
}

.scenario-icon {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 20rpx;
}

.scenario-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.scenario-desc {
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.4;
}

/* Sheet content */
.sheet-content {
  display: flex;
  flex-direction: column;
}

.sentence-list {
  padding: 0 8rpx;
}

.sentence-item {
  padding: 28rpx 0;
  border-bottom: 1px solid #F3F4F6;
}

.sentence-item:last-child {
  border-bottom: none;
}
.sentence-zh {
  font-size: 30rpx;
  font-weight: 500;
  color: #111827;
  margin-bottom: 8rpx;
}

.sentence-en {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.5;
}

.sentence-list-wrap {
  position: relative;
}

.loading-overlay {
  height: 50vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: conic-gradient(#E5E7EB, #9CA3AF);
  animation: spin 0.8s linear infinite;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner-inner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.refresh-action {
  display: flex;
  justify-content: center;
  padding: 28rpx 0 8rpx;
}

.refresh-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.sheet-action {
  padding-top: 40rpx;
}

.drill-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #111827;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
