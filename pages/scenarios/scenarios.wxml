<navigation-bar title="场景练习" back="{{true}}" color="black" background="#FAFAFA">
</navigation-bar>

<view class="page">
  <view class="scenario-grid">
    <view
      class="scenario-card"
      wx:for="{{scenarios}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onScenarioTap"
      hover-class="scenario-card-press"
      hover-start-time="0"
      hover-stay-time="80">
      <view class="scenario-icon">{{item.icon}}</view>
      <view class="scenario-name">{{item.name}}</view>
      <view class="scenario-desc">{{item.desc}}</view>
    </view>
  </view>
</view>

<bottom-modal
  show="{{showSheet}}"
  title="来自「{{currentScenario.name}}」的3句口语"
  showCancel="{{true}}"
  cancelText="关闭"
  bind:close="closeSheet">
  <view class="sheet-content">
    <view class="sentence-list-wrap">
      <view wx:if="{{refreshing}}" class="loading-overlay">
        <view class="loading-spinner">
          <view class="loading-spinner-inner"></view>
        </view>
      </view>
      <scroll-view scroll-y style="height: 50vh" class="sentence-list" wx:if="{{!refreshing}}">
        <view class="sentence-items">
          <view class="sentence-item" wx:for="{{currentSentences}}" wx:key="id">
            <view class="sentence-zh">{{item.zh}}</view>
            <view class="sentence-en">{{item.en}}</view>
          </view>
        </view>
        <view class="refresh-action" bindtap="refreshSentences">
          <text class="refresh-text">换一批</text>
        </view>
      </scroll-view>
    </view>
    <view class="sheet-action">
      <view class="drill-btn" bindtap="drillScenario">练习</view>
    </view>
  </view>
</bottom-modal>
