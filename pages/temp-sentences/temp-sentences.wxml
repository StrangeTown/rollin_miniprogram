<navigation-bar title="临时口语句子" back="{{true}}" color="black" background="#FAFAFA">
</navigation-bar>

<view class="page">
  <view class="input-section">
    <input
      class="sentence-input"
      value="{{inputValue}}"
      focus="{{focusInput}}"
      placeholder="记一句临时想背的口语"
      placeholder-class="sentence-input-placeholder"
      confirm-type="done"
      bindinput="onInput"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      bindconfirm="onInputConfirm" />
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="content">
    <view wx:if="{{sentences.length}}" class="sentence-list">
      <view class="sentence-item" wx:for="{{sentences}}" wx:key="id">
        <view class="sentence-text">{{item.text}}</view>
        <view class="sentence-delete" data-id="{{item.id}}" bindtap="onDeleteSentence">删除</view>
      </view>
    </view>

    <view wx:else class="empty-state">这里会暂存你临时想背的口语句子</view>
  </scroll-view>

  <view class="footer-actions">
    <view class="footer-btn footer-btn-copy" bindtap="copyAll">复制全部</view>
    <view class="footer-btn footer-btn-delete" bindtap="confirmClearAll">删除全部</view>
  </view>
</view>