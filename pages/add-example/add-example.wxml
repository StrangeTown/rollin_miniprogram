<navigation-bar title="添加例句" back="{{true}}" color="black" background="#FAFAFA"></navigation-bar>

<view class="page">
  <view class="header-section">
    <view class="structure-row">
      <view class="structure-text">{{structure}}</view>
      <view class="structure-copy" bindtap="copyStructure">复制</view>
    </view>
  </view>

  <view class="input-card">
    <view class="input-group">
      <view class="input-title">英文例句</view>
      <textarea class="custom-textarea en-text" placeholder="结合自己的生活造个新句..." placeholder-class="placeholder" auto-height bindinput="onEnInput" value="{{en}}"></textarea>
    </view>

    <view class="divider"></view>

    <view class="input-group">
      <view class="input-title">中文翻译</view>
      <textarea class="custom-textarea zh-text" placeholder="输入这句英文的意思..." placeholder-class="placeholder" auto-height bindinput="onZhInput" value="{{zh}}"></textarea>
    </view>
  </view>

  <view class="writing-tip">
    尽量贴近你熟悉的真实场景，也可以好笑一点、夸张一点、出人意料一点。越有画面和情绪，越容易记住。
  </view>

  <view class="btn-area">
    <view class="save-btn {{canSave ? 'active' : ''}}" bindtap="onSave">保存</view>
    <view wx:if="{{customList.length > 0}}" class="list-entry" bindtap="openListSheet">已添加例句 ({{customList.length}})</view>
  </view>
</view>

<view wx:if="{{showListSheet}}" class="list-sheet-mask" bindtap="closeListSheet" catchtouchmove="noop">
  <view class="list-sheet" catchtap="noop" catchtouchmove="noop">
    <view class="list-sheet-header">
      <view class="list-sheet-title">已添加例句</view>
      <view class="list-sheet-close" bindtap="closeListSheet">关闭</view>
    </view>
    <view class="list-sheet-body">
      <view wx:for="{{customList}}" wx:key="index" class="example-card">
        <view class="example-content">
          <view class="example-en">{{item.en}}</view>
          <view class="example-zh">{{item.zh}}</view>
        </view>
        <view class="example-delete" data-idx="{{index}}" bindtap="deleteExample">删除</view>
      </view>
      <view wx:if="{{customList.length > 1}}" class="delete-all" bindtap="deleteAllExamples">删除以上例句</view>
    </view>
  </view>
</view>
