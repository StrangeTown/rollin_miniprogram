page {
  background-color: #FAFAFA;
}

.page {
  min-height: 100vh;
  background-color: #FAFAFA;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx 180rpx;
  box-sizing: border-box;
}

.header-section {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.structure-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  column-gap: 24rpx;
}

.structure-text {
  flex: 1;
  min-width: 0;
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.4;
  word-break: normal;
  overflow-wrap: normal;
}

.structure-copy {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: rgba(17, 24, 39, 0.04);
  color: #6B7280;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  flex-shrink: 0;
}

.structure-copy:active {
  background: rgba(17, 24, 39, 0.08);
  color: #4B5563;
}

.input-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 40rpx 80rpx -12rpx rgba(0, 0, 0, 0.05), 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.input-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
  margin-bottom: 24rpx;
}

.custom-textarea {
  width: 100%;
  min-height: 80rpx;
  font-size: 36rpx;
  color: #111827;
  line-height: 1.5;
}

.en-text {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-weight: 500;
}

.zh-text {
  font-weight: 600;
  font-size: 34rpx;
}

.placeholder {
  color: #D1D5DB;
  font-weight: 400;
}

.divider {
  width: 100%;
  height: 2rpx;
  background-color: #F3F4F6;
  margin: 48rpx 0;
}

.writing-tip {
  margin-top: 32rpx;
  padding: 0 8rpx;
  font-size: 24rpx;
  line-height: 1.9;
  color: rgba(107, 114, 128, 0.56);
}

.btn-area {
  margin-top: 80rpx;
  width: 100%;
}

.save-btn {
  width: 100%;
  height: 104rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  background: #E5E7EB;
  color: #9CA3AF;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: none;
}

.save-btn.active {
  background: #111827;
  color: #FFFFFF;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
}

.save-btn.active:active {
  transform: scale(0.97);
}

.list-entry {
  margin-top: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #9CA3AF;
  text-decoration: underline;
  text-underline-offset: 6rpx;
  text-decoration-thickness: 2rpx;
  padding: 16rpx 0;
  transition: color 0.2s;
}

.list-entry:active {
  color: #6B7280;
}

/* Custom Examples List Sheet */
.list-sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  background: rgba(17, 24, 39, 0.4);
  display: flex;
  align-items: flex-end;
  animation: listFadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes listFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.list-sheet {
  width: 100%;
  height: 78vh;
  background: #FAFAFA;
  border-radius: 48rpx 48rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  animation: listSheetUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
}

@keyframes listSheetUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.list-sheet-header {
  height: 96rpx;
  padding: 0 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.list-sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.list-sheet-close {
  position: absolute;
  right: 32rpx;
  min-height: 88rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #6B7280;
  display: flex;
  align-items: center;
  transition: color 0.2s;
}

.list-sheet-close:active {
  color: #111827;
}

.list-sheet-body {
  flex: 1;
  padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  overflow-y: auto;
  box-sizing: border-box;
}

.example-card {
  width: 100%;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 20rpx;
}

.example-content {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.example-en {
  font-size: 30rpx;
  font-weight: 500;
  color: #111827;
  line-height: 1.5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  word-break: break-word;
}

.example-zh {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.4;
}

.example-delete {
  font-size: 26rpx;
  font-weight: 500;
  color: #D1D5DB;
  padding: 12rpx 16rpx;
  flex-shrink: 0;
  transition: color 0.2s;
}

.example-delete:active {
  color: #EF4444;
}

.delete-all {
  margin-top: 40rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #D1D5DB;
  transition: color 0.2s;
}

.delete-all:active {
  color: #EF4444;
}
